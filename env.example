# Copy this file to .env and adjust if needed -- .env itself is gitignored,
# so each machine keeps its own local copy without ever pushing secrets.
#
#   cp .env.example .env

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
MINIO_ENDPOINT=http://localhost:9000

# Snowflake -- from your trial account (Admin > Accounts, or the signup
# confirmation email). Account format: orgname-accountname (or the
# legacy orgname.region.cloud form for older accounts).
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=NIDD_WH
SNOWFLAKE_DATABASE=NIDD_DB
SNOWFLAKE_SCHEMA=SILVER
